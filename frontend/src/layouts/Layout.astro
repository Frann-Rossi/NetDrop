---
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>NetDrop - Dashboard</title>

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>

		<!-- FontAwesome para los iconos que devuelve la API -->
		<link
			rel="stylesheet"
			href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
		/>
	</head>
	<body
		class="bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-100 font-sans min-h-screen relative overflow-x-hidden selection:bg-cyan-500/30 selection:text-cyan-200 transition-colors duration-500"
	>
		<!-- Background Effects -->
		<div class="fixed inset-0 z-[-1] pointer-events-none transition-colors duration-700">
			<!-- Dark Mode Glow (Midnight) -->
			<div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] rounded-full bg-cyan-500/10 blur-[120px] opacity-0 dark:opacity-100 transition-opacity duration-700"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] rounded-full bg-blue-600/10 blur-[120px] opacity-0 dark:opacity-100 transition-opacity duration-700"></div>
			
			<!-- Light Mode Glow (Clean) -->
			<div class="absolute top-[10%] right-[10%] w-[40%] h-[40%] rounded-full bg-blue-500/[0.03] blur-[100px] opacity-100 dark:opacity-0 transition-opacity duration-700"></div>
		</div>

		<main class="max-w-7xl mx-auto px-4 py-8 relative z-10">
			<slot />
		</main>
	</body>
</html>
