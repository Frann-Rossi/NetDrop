---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ToastContainer from '../components/ToastContainer.astro';
import UploadZone from '../components/UploadZone.astro';
import FileList from '../components/FileList.astro';
import LoginModal from '../components/LoginModal.astro';
import DeleteModal from '../components/DeleteModal.astro';
---

<Layout>
  <Header />
  <!-- Banner de IP para conectarse desde otros dispositivos -->
  <div id="networkBanner" class="hidden mb-8 animate-slide-up" style="animation-delay: 100ms;">
    <div class="glass-card rounded-2xl p-6 border border-white/5">
      <div class="flex flex-col sm:flex-row items-center gap-6">
        <!-- Icono -->
        <div class="w-12 h-12 rounded-xl bg-cyan-500/10 flex items-center justify-center shrink-0">
          <i class="fa-solid fa-wifi text-cyan-400 text-xl"></i>
        </div>
        
        <!-- Info Principal -->
        <div class="flex-grow text-center sm:text-left min-w-0">
          <p class="text-[10px] uppercase tracking-[0.2em] text-slate-500 font-black mb-1">Acceso Local</p>
          <p class="text-xl sm:text-2xl font-bold text-white break-all" id="networkUrl">...</p>
        </div>

        <!-- Botón y QR -->
        <div class="flex items-center gap-4 w-full sm:w-auto justify-center sm:justify-end">
          <button id="shareNetworkUrl" class="flex-grow sm:flex-grow-0 px-6 py-2.5 rounded-xl bg-cyan-600 hover:bg-cyan-500 text-white font-bold transition-all shadow-lg shadow-cyan-600/20 flex items-center justify-center gap-2">
            <i class="fa-solid fa-share-nodes"></i>
            <span>Compartir</span>
          </button>
          <div class="p-1 bg-white rounded-lg shrink-0">
            <img id="networkQr" src="" alt="QR" class="w-12 h-12 sm:w-14 sm:h-14" />
          </div>
        </div>
      </div>
    </div>
  </div>
  <ToastContainer />
  <UploadZone />
  <FileList />
  <LoginModal />
  <DeleteModal />
</Layout>

<script src="../scripts/app.js"></script>
