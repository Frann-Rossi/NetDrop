---
// src/components/DeleteModal.astro
import Modal from './Modal.astro';
---
<!-- Confirm Delete Modal -->
<Modal id="deleteModal" contentId="deleteModalContent" maxWidth="sm">
  <div class="text-center mb-6">
    <div class="w-16 h-16 rounded-full bg-rose-500/20 flex items-center justify-center mx-auto mb-4">
      <i class="fa-solid fa-trash-can text-3xl text-rose-500"></i>
    </div>
    <h2 class="text-xl font-bold text-white mb-2">¿Eliminar Archivo?</h2>
    <p class="text-slate-400 text-sm">Estás a punto de eliminar <span id="deleteFileName" class="text-white font-medium break-all"></span>. Esta acción no se puede deshacer.</p>
  </div>
  <div class="flex gap-3">
    <button id="cancelDeleteBtn" class="flex-1 py-3 rounded-xl font-medium text-slate-300 bg-slate-800 hover:bg-slate-700 transition-colors">Cancelar</button>
    <button id="confirmDeleteBtn" class="flex-1 py-3 rounded-xl font-semibold text-white bg-rose-600 hover:bg-rose-500 transition-colors shadow-[0_0_15px_rgba(225,29,72,0.3)]">Eliminar</button>
  </div>
</Modal>
