---
// src/components/LoginModal.astro
import Modal from './Modal.astro';
---
<!-- Login Modal -->
<Modal id="loginModal" contentId="loginModalContent" maxWidth="sm">
  <div class="text-center mb-8">
    <i class="fa-solid fa-lock text-4xl text-cyan-400 mb-4"></i>
    <h2 class="text-2xl font-bold text-white">Acceso Restringido</h2>
    <p class="text-slate-400 mt-2 text-sm">Ingresa tus credenciales para continuar</p>
  </div>
  
  <form id="loginForm" class="space-y-4">
    <div>
      <label class="block text-xs font-medium text-slate-400 uppercase tracking-wider mb-1">Usuario</label>
      <input type="text" id="username" required class="w-full bg-slate-900/50 border border-white/10 rounded-xl py-3 px-4 text-white focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-all" />
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-400 uppercase tracking-wider mb-1">Contraseña</label>
      <input type="password" id="password" required class="w-full bg-slate-900/50 border border-white/10 rounded-xl py-3 px-4 text-white focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-all" />
    </div>
    <button type="submit" class="w-full bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-400 hover:to-blue-500 text-white font-semibold rounded-xl py-3 mt-4 transition-all hover:shadow-[0_0_20px_rgba(6,182,212,0.4)] active:scale-[0.98]">
      Entrar
    </button>
  </form>
</Modal>
