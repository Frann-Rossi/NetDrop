---
// src/components/Clipboard.astro
---
<div class="glass-card p-6 rounded-3xl mb-8 animate-slide-up" style="animation-delay: 200ms;">
  <div class="flex items-center gap-3 mb-6">
    <div class="w-10 h-10 rounded-xl bg-violet-500/10 flex items-center justify-center">
      <i class="fa-solid fa-clipboard text-violet-400 text-lg"></i>
    </div>
    <div class="flex-grow">
      <h3 class="text-lg font-bold">Portapapeles Sincronizado</h3>
      <p class="text-[10px] text-app-text-dim uppercase tracking-widest font-black">Historial reciente</p>
    </div>
    <div class="h-8 w-8 rounded-full bg-slate-800/20 flex items-center justify-center" id="clipboardStatus" title="Sincronizado">
      <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
    </div>
  </div>

  <div class="space-y-4">
    <!-- Input -->
    <div class="relative group">
      <textarea id="clipboardInput" placeholder="Escribe algo para compartir..." 
        class="w-full bg-slate-900/5 border border-app-border rounded-2xl p-4 text-sm focus:outline-none focus:border-violet-500 transition-all resize-none min-h-[100px]"></textarea>
      <button id="sendClipboard" class="absolute bottom-3 right-3 p-2 bg-violet-600 hover:bg-violet-500 text-white rounded-xl transition-all scale-90 opacity-0 group-focus-within:scale-100 group-focus-within:opacity-100 shadow-lg shadow-violet-600/20">
        <i class="fa-solid fa-paper-plane"></i>
      </button>
    </div>

    <!-- Historial -->
    <div id="clipboardHistory" class="flex flex-col gap-2">
      <!-- Items will be injected here -->
       <p class="text-center text-app-text-dim text-[10px] py-4 italic uppercase tracking-widest">Cargando...</p>
    </div>
  </div>
</div>
