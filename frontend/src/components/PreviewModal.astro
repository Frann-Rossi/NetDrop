---
// src/components/PreviewModal.astro
import Modal from './Modal.astro';
---
<Modal id="previewModal" contentId="previewModalContent" maxWidth="2xl">
  <div class="flex items-center justify-between mb-4">
    <h3 id="previewTitle" class="text-xl font-bold truncate pr-8">Previsualización</h3>
    <button id="closePreview" class="text-app-text-dim hover:text-white transition-colors">
      <i class="fa-solid fa-xmark text-xl"></i>
    </button>
  </div>

  <div id="previewBody" class="w-full min-h-[300px] bg-slate-950/40 rounded-2xl flex items-center justify-center overflow-hidden border border-white/5">
    <!-- El contenido (img, video, audio, embed) se inyectará dinámicamente -->
    <div class="animate-pulse flex flex-col items-center gap-4">
      <div class="w-16 h-16 rounded-full bg-slate-800"></div>
      <div class="w-32 h-4 bg-slate-800 rounded"></div>
    </div>
  </div>

  <div class="flex justify-between items-center mt-6">
    <div class="text-xs text-app-text-dim">
      <span id="previewMeta">Archivo multimedia</span>
    </div>
    <div class="flex gap-3">
      <button id="previewFull" class="px-5 py-2 rounded-xl bg-slate-800 hover:bg-slate-700 text-sm font-semibold transition-all">
        Ver original
      </button>
      <button id="previewDownload" class="px-5 py-2 rounded-xl bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-semibold transition-all shadow-lg shadow-emerald-600/20">
        Descargar
      </button>
    </div>
  </div>
</Modal>

<style is:global>
  #previewBody img { max-width: 100%; max-height: 70vh; object-fit: contain; }
  #previewBody video { max-width: 100%; max-height: 70vh; }
  #previewBody audio { width: 80%; }
  #previewBody embed, #previewBody iframe { width: 100%; height: 70vh; border: none; }
</style>
