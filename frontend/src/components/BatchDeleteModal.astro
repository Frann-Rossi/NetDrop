---
// src/components/BatchDeleteModal.astro
---
<div id="batchDeleteModal" class="fixed inset-0 z-[110] flex items-center justify-center hidden opacity-0 transition-opacity duration-300 pointer-events-none">
  <div class="absolute inset-0 bg-black/90 backdrop-blur-md"></div>
  <div id="batchDeleteModalContent" class="relative glass-card rounded-[2.5rem] p-10 max-w-md w-full mx-4 transform scale-95 transition-transform duration-300 border-rose-500/20">
    <div class="text-center">
      <div class="w-20 h-20 rounded-3xl bg-rose-500/10 flex items-center justify-center mx-auto mb-6 animate-pulse">
        <i class="fa-solid fa-trash-can text-4xl text-rose-500"></i>
      </div>
      <h3 class="text-2xl font-black mb-2 uppercase tracking-tight">¿Confirmar Eliminación?</h3>
      <p class="text-app-text-dim text-sm mb-8 font-medium">Estás a punto de borrar <span id="batchCountText" class="text-white font-black bg-rose-500/20 px-2 py-0.5 rounded">0</span> archivos. Esta acción no se puede deshacer.</p>
      
      <div class="flex flex-col gap-3">
        <button id="confirmBatchDeleteBtn" class="w-full py-4 rounded-2xl bg-rose-600 hover:bg-rose-500 text-white font-black transition-all shadow-xl shadow-rose-600/30 hover:-translate-y-1 active:translate-y-0">
          ELIMINAR AHORA
        </button>
        <button id="cancelBatchDeleteBtn" class="w-full py-4 rounded-2xl bg-slate-900/50 text-app-text-dim hover:text-white font-bold transition-all border border-white/5">
          CANCELAR
        </button>
      </div>
    </div>
  </div>
</div>
