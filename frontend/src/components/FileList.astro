---
// src/components/FileList.astro
---
<!-- Filtro y Lista de Archivos -->
<section class="animate-slide-up" style="animation-delay: 200ms;">
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
    <h2 class="text-xl font-semibold flex items-center gap-2">
      <i class="fa-solid fa-hard-drive text-slate-400"></i> Mis Archivos
    </h2>
    <div class="relative w-full sm:w-64">
      <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
      <input type="text" id="searchInput" placeholder="Buscar..." class="w-full bg-slate-900/60 border border-white/10 rounded-full py-2 pl-10 pr-4 text-sm focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-all placeholder:text-slate-500" />
    </div>
  </div>

  <!-- Loading State -->
  <div id="filesLoading" class="flex flex-col items-center justify-center py-20 text-slate-500">
    <i class="fa-solid fa-circle-notch animate-spin text-4xl mb-4 text-slate-700"></i>
    <p>Cargando archivos...</p>
  </div>

  <!-- Empty State -->
  <div id="filesEmpty" class="hidden flex-col items-center justify-center py-20 text-slate-500">
    <i class="fa-solid fa-ghost text-5xl mb-4 opacity-50"></i>
    <p>No hay archivos en el servidor</p>
  </div>

  <!-- File Grid -->
  <div id="fileList" class="grid grid-cols-1 md:grid-cols-2 gap-4 hidden">
    <!-- Los archivos se inyectan aquí mediante JS -->
  </div>
</section>
