---
// src/components/FileList.astro
---
<section class="animate-slide-up" style="animation-delay: 300ms;">
  <!-- Sub-Header: Acciones y Búsqueda -->
  <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-6 mb-8 mt-4">
    <div class="flex items-center gap-4">
      <div class="w-12 h-12 rounded-2xl bg-cyan-500/10 flex items-center justify-center border border-cyan-500/10">
        <i class="fa-solid fa-folder-tree text-cyan-400 text-xl"></i>
      </div>
      <div>
        <h3 class="text-2xl font-black tracking-tight text-white">Archivos</h3>
        <p class="text-[9px] text-app-text-dim uppercase tracking-[0.4em] font-black opacity-60">Repositorio Local</p>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-4 w-full lg:w-auto">
      <div class="relative flex-grow lg:flex-grow-0">
        <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-slate-500 text-sm"></i>
        <input type="text" id="searchInput" placeholder="Filtrar por nombre..." 
          class="w-full lg:w-72 bg-slate-900/60 border border-white/5 rounded-2xl py-3.5 pl-12 pr-6 text-sm font-medium focus:outline-none focus:border-cyan-500/50 focus:ring-4 focus:ring-cyan-500/5 transition-all placeholder:text-slate-600" />
      </div>
      
      <select id="sortSelect" class="bg-slate-900/60 border border-white/5 rounded-2xl py-3.5 px-6 text-sm font-bold focus:outline-none focus:border-cyan-500/50 transition-all cursor-pointer">
        <option value="date-desc">Recientes</option>
        <option value="date-asc">Antiguos</option>
        <option value="name-asc">A - Z</option>
        <option value="size-desc">Tamaño</option>
      </select>
    </div>
  </div>

  <!-- Main Grid (v4.0 Robust 1-2 Col) -->
  <div id="fileList" class="grid grid-cols-1 gap-6 w-full items-start">
    <!-- Archivos inyectados por app.js -->
  </div>

  <!-- Loading State -->
  <div id="filesLoading" class="hidden py-32 flex flex-col items-center gap-6">
    <div class="relative w-12 h-12">
      <div class="absolute inset-0 border-4 border-slate-800 rounded-full"></div>
      <div class="absolute inset-0 border-4 border-cyan-500 border-t-transparent rounded-full animate-spin"></div>
    </div>
    <p class="text-app-text-dim font-bold tracking-widest uppercase text-[10px]">Sincronizando...</p>
  </div>

  <!-- Empty State -->
  <div id="filesEmpty" class="hidden py-24 flex flex-col items-center text-center gap-6 glass-card rounded-[3rem] border-dashed">
    <div class="w-24 h-24 rounded-[2rem] bg-slate-900/50 flex items-center justify-center border border-white/5">
      <i class="fa-solid fa-box-open text-5xl text-slate-700"></i>
    </div>
    <div class="max-w-xs">
      <h4 class="text-xl font-black text-white mb-2">Está desierto por aquí</h4>
      <p class="text-app-text-dim text-sm font-medium">Sube archivos desde la zona superior para comenzar a compartir.</p>
    </div>
  </div>
</section>
